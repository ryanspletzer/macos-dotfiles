{
  "env": {
    "DISABLE_AUTOUPDATER": "1"
  },
  "permissions": {
    "additionalDirectories": [
      "~/.gnupg"
    ]
  },
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/approve-variants.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/check-uv-pytest.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/check-uv-venv.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/check-pip-install.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/check-pipx.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay -v 0.40 /System/Library/Sounds/Morse.aiff"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "afplay -v 0.35 /System/Library/Sounds/Ping.aiff"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "oh-my-posh claude --config ~/.oh-my-posh/themes/claude-statusline.yaml",
    "padding": 0
  },
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "github@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": true,
    "markdown-linter-fixer@markdown-linter-fixer-marketplace": true,
    "superpowers@superpowers-marketplace": false,
    "elements-of-style@superpowers-marketplace": false,
    "episodic-memory@superpowers-marketplace": true,
    "security-guidance@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": false,
    "gopls-lsp@claude-plugins-official": false,
    "csharp-lsp@claude-plugins-official": false,
    "rust-analyzer-lsp@claude-plugins-official": false,
    "swift-lsp@claude-plugins-official": false,
    "lua-lsp@claude-plugins-official": false,
    "powershell-editor-services@claude-code-lsps": false,
    "playwright@claude-plugins-official": false,
    "serena@claude-plugins-official": false,
    "context7@claude-plugins-official": false,
    "commands-code-analysis-testing@buildwithclaude": false,
    "accesslint@accesslint": false,
    "frontend-design@claude-plugins-official": false,
    "obsidian-skills@buildwithclaude": false,
    "ralph-wiggum@claude-plugins-official": false,
    "ralph-loop@claude-plugins-official": false,
    "compound-engineering@every-marketplace": false,
    "agents-development-architecture@buildwithclaude": false
  },
  "sandbox": {
    "network": {
      "allowUnixSockets": [
        "~/.gnupg/S.gpg-agent",
        "~/.gnupg/S.gpg-agent.browser",
        "~/.gnupg/S.gpg-agent.extra",
        "~/.gnupg/S.gpg-agent.ssh"
      ]
    }
  },
  "syntaxHighlightingDisabled": false
}
